# ngrok tunnel authentication token
# get yours at https://dashboard.ngrok.com/authtokens
NGROK_AUTHTOKEN=

# Your local AI server base URL (FastAPI server with /chat endpoint)
# Leave empty to skip local provider
# Example: http://localhost:8005 or https://ai-node14-farm13.dxesk.cloud
LOCAL_AI_BASE_URL=

# Local AI model to use (must be available on your Ollama server)
# Example: mistral:latest, gemma3:27b, deepseek-v2:16b
LOCAL_AI_MODEL=mistral:latest

# Gemini API key — fallback if local AI not configured
# get yours free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Server port (default: 8787)
PORT=
