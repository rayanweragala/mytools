{
  "name": "mytools",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:api": "tsx src/server.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:client\"",
    "build:client": "vite build",
    "build:api": "tsc -p tsconfig.json",
    "build": "npm run build:client && npm run build:api",
    "start": "node dist/server.js",
    "worker:up": "node scripts/devctl.mjs start",
    "worker:stop": "node scripts/devctl.mjs stop",
    "worker:restart": "node scripts/devctl.mjs restart",
    "worker:status": "node scripts/devctl.mjs status",
    "worker:logs": "node scripts/devctl.mjs logs"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "^3.13.23",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "fuse.js": "^7.3.0",
    "ngrok": "^5.0.0-beta.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.8"
  }
}
