{
  "name": "mytools",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "worker:up": "node scripts/devctl.mjs start",
    "worker:stop": "node scripts/devctl.mjs stop",
    "worker:restart": "node scripts/devctl.mjs restart",
    "worker:status": "node scripts/devctl.mjs status",
    "worker:logs": "node scripts/devctl.mjs logs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "ngrok": "^5.0.0-beta.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
