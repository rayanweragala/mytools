# ngrok tunnel authentication token
# get yours at https://dashboard.ngrok.com/authtokens
NGROK_AUTHTOKEN=

# Local AI server base URL (served by your local/private provider)
# Leave empty to disable local provider fallback
LOCAL_AI_BASE_URL=

# Local AI model identifier provided by your AI server
LOCAL_AI_MODEL=

# Gemini API key — fallback if local AI not configured
# get yours free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Server port (default: 8787)
PORT=
